---
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';

const articles = [
  {
    href: '/news/article-detail/',
    title: '第3回ユーザー会開催レポート',
    date: '2024-10-22',
    tags: [{ label: 'イベント', href: '/tag/tag-event/' }],
  },
  {
    href: '/news/article-detail/',
    title: '製品ラインナップ刷新のお知らせ',
    date: '2024-07-15',
    tags: [
      { label: 'リブランド', href: '/tag/tag-rebrand/' },
      { label: 'アップデート', href: '/tag/tag-update/' },
    ],
  },
  {
    href: '/news/article-detail/',
    title: 'ベータユーザー募集セミナー開催',
    date: '2024-02-20',
    tags: [{ label: 'イベント', href: '/tag/tag-event/' }],
  },
];
---
<Layout title="導入事例 | Sample Blog">
  <main class="main">
    <div class="container">
      <p class="page-lead" style="margin-bottom: 4px;">キーワード</p>
      <h1 class="page-title">導入事例</h1>
      <p class="page-lead">お客様の導入事例や活用シーンを紹介する特集ページ。</p>

      <div class="card-grid">
        {articles.map((a) => (
          <Card href={a.href} title={a.title} date={a.date} tags={a.tags} />
        ))}
      </div>
    </div>
  </main>
</Layout>
