---
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';

const articles = [
  {
    href: '/news/article-detail/',
    title: '既存製品アップデート（v2.5）リリース',
    date: '2026-01-30',
    tags: [
      { label: 'アップデート', href: '/tag/tag-update/' },
      { label: '技術情報', href: '/tag/tag-tech/' },
    ],
  },
  {
    href: '/news/article-detail/',
    title: '技術カンファレンス2025登壇報告',
    date: '2025-11-05',
    tags: [
      { label: 'イベント', href: '/tag/tag-event/' },
      { label: '技術情報', href: '/tag/tag-tech/' },
      { label: 'トピックス', href: '/tag/tag-topics/' },
    ],
  },
  {
    href: '/news/article-detail/',
    title: '新シリーズ「Sample Lite」発売のお知らせ',
    date: '2025-09-18',
    tags: [{ label: '新製品', href: '/tag/tag-newproduct/' }],
  },
];
---
<Layout title="技術情報 | Sample Blog">
  <main class="main">
    <div class="container">
      <p class="page-lead" style="margin-bottom: 4px;">キーワード</p>
      <h1 class="page-title">技術情報</h1>
      <p class="page-lead">製品技術や仕組みに関する解説・コラム記事を集めた特集ページ。</p>

      <div class="card-grid">
        {articles.map((a) => (
          <Card href={a.href} title={a.title} date={a.date} tags={a.tags} />
        ))}
      </div>
    </div>
  </main>
</Layout>
