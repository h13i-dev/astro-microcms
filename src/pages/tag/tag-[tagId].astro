---
import type { GetStaticPaths } from 'astro';
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';
import { getTagsList, getNewsList, type TagContent } from '../../library/microcms';

export const getStaticPaths = (async () => {
  const { contents } = await getTagsList({ limit: 100 });
  return contents.map((tag) => ({
    params: { tagId: tag.id },
    props: { tag },
  }));
}) satisfies GetStaticPaths;

interface Props {
  tag: TagContent;
}

const { tagId } = Astro.params;
const { tag } = Astro.props;

const { contents: newsList } = await getNewsList({
  filters: `tags[contains]${tagId}`,
  orders: '-publishedAt',
  limit: 100,
});

const articles = newsList.map((n) => ({
  href: `/news/${n.id}/`,
  title: n.title,
  date: (n.publishedAt ?? n.createdAt).slice(0, 10),
  imgSrc: n.thumbnail?.url,
  tags: n.tags.map((t) => ({
    label: t.name,
    href: `/tag/tag-${t.id}/`,
  })),
}));
---
<Layout title={`タグ: ${tag.name} | Sample Blog`}>
  <main class="main">
    <div class="container">
      <p class="page-lead" style="margin-bottom: 4px;"><a href="/tag/" style="color: inherit;">タグ</a></p>
      <h1 class="page-title"># {tag.name}</h1>
      <p class="page-lead">「{tag.name}」タグの付いた記事の一覧です。</p>

      {articles.length > 0 ? (
        <div class="card-grid">
          {articles.map((a) => (
            <Card
              href={a.href}
              title={a.title}
              date={a.date}
              tags={a.tags}
              imgSrc={a.imgSrc}
            />
          ))}
        </div>
      ) : (
        <p class="empty">該当する記事はありません。</p>
      )}
    </div>
  </main>
</Layout>
