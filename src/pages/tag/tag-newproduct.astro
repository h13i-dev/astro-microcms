---
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';

const articles = [
  {
    href: '/news/article-detail/',
    title: '新製品「Sample Pro X1」を発表しました',
    date: '2026-04-12',
    tags: [
      { label: '新製品', href: '/tag/tag-newproduct/' },
      { label: 'トピックス', href: '/tag/tag-topics/' },
    ],
  },
  {
    href: '/news/article-detail/',
    title: '春の新製品発表会を開催します',
    date: '2026-02-15',
    tags: [
      { label: 'イベント', href: '/tag/tag-event/' },
      { label: '新製品', href: '/tag/tag-newproduct/' },
    ],
  },
  {
    href: '/news/article-detail/',
    title: '新シリーズ「Sample Lite」発売のお知らせ',
    date: '2025-09-18',
    tags: [{ label: '新製品', href: '/tag/tag-newproduct/' }],
  },
];
---
<Layout title="タグ: 新製品 | Sample Blog">
  <main class="main">
    <div class="container">
      <p class="page-lead" style="margin-bottom: 4px;"><a href="/tag/" style="color: inherit;">タグ</a></p>
      <h1 class="page-title"># 新製品</h1>
      <p class="page-lead">「新製品」タグの付いた記事の一覧です。</p>

      <div class="card-grid">
        {articles.map((a) => (
          <Card href={a.href} title={a.title} date={a.date} tags={a.tags} />
        ))}
      </div>
    </div>
  </main>
</Layout>
