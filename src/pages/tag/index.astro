---
import Layout from '../../layouts/Layout.astro';
import { getTagsList, getNewsList } from '../../library/microcms';

const [{ contents: tagsList }, { contents: allNews }] = await Promise.all([
  getTagsList({ limit: 100 }),
  getNewsList({ limit: 100, fields: 'tags' }),
]);

const tagCounts = new Map<string, number>();
for (const news of allNews) {
  for (const tag of news.tags) {
    tagCounts.set(tag.id, (tagCounts.get(tag.id) ?? 0) + 1);
  }
}

const tags = tagsList.map((t) => ({
  href: `/tag/tag-${t.id}/`,
  label: t.name,
  count: tagCounts.get(t.id) ?? 0,
}));
---
<Layout title="タグ一覧 | Sample Blog">
  <main class="main">
    <div class="container">
      <h1 class="page-title">タグ一覧</h1>
      <p class="page-lead">記事に付与されているタグの一覧。クリックすると該当タグの記事を表示します。</p>

      <div class="tag-list-large">
        {tags.map((t) => (
          <a href={t.href} class="tag-chip-large">
            {t.label} <span class="tag-count">{t.count}</span>
          </a>
        ))}
      </div>
    </div>
  </main>
</Layout>
