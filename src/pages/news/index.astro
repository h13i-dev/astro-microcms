---
import Layout from '../../layouts/Layout.astro';
import ArticleListItem from '../../components/ArticleListItem.astro';
import { getNewsList } from '../../library/microcms';

const { contents: newsList } = await getNewsList({
  limit: 100,
  orders: '-publishedAt',
});

type Category = 'product' | 'event';

const articles = newsList.map((n) => ({
  href: `/news/${n.id}/`,
  date: (n.publishedAt ?? n.createdAt).slice(0, 10),
  category: n.category.id as Category,
  title: n.title,
  excerpt: n.description,
}));

const years = Array.from(new Set(articles.map((a) => a.date.slice(0, 4))))
  .sort()
  .reverse();
const initialYear = years[0] ?? '';

const categories: Array<{ key: 'all' | Category; label: string }> = [
  { key: 'all', label: '全て' },
  { key: 'product', label: '製品' },
  { key: 'event', label: 'イベント' },
];
---
<Layout title="記事アーカイブ | Sample Blog">
  <main class="main">
    <div class="container">
      <h1 class="page-title">記事アーカイブ</h1>
      <p class="page-lead">過去の記事を年別・カテゴリ別に絞り込めます。</p>

      <div class="year-tabs" role="tablist">
        {years.map((y) => (
          <button
            class:list={['year-tab', { 'is-active': y === initialYear }]}
            data-year={y}
            role="tab"
          >{y}</button>
        ))}
      </div>

      <div class="category-filter">
        {categories.map((c) => (
          <button
            class:list={['cat-btn', { 'is-active': c.key === 'all' }]}
            data-cat={c.key}
          >{c.label}</button>
        ))}
      </div>

      <ul class="article-list">
        {articles.map((a) => (
          <ArticleListItem
            href={a.href}
            date={a.date}
            category={a.category}
            title={a.title}
            excerpt={a.excerpt}
            isHidden={a.date.slice(0, 4) !== initialYear}
          />
        ))}
      </ul>

      <p class="empty" hidden id="empty-state">該当する記事はありません。</p>
    </div>
  </main>
</Layout>

<script>
  const yearTabs = document.querySelectorAll<HTMLButtonElement>('.year-tab');
  const catBtns = document.querySelectorAll<HTMLButtonElement>('.cat-btn');
  const items = document.querySelectorAll<HTMLLIElement>('.article-item');
  const emptyState = document.getElementById('empty-state') as HTMLParagraphElement | null;
  const initialActiveTab = document.querySelector<HTMLButtonElement>('.year-tab.is-active');

  let currentYear = initialActiveTab?.dataset.year ?? '';
  let currentCat = 'all';

  function applyFilter() {
    let visibleCount = 0;
    items.forEach((item) => {
      const matchYear = item.dataset.year === currentYear;
      const matchCat = currentCat === 'all' || item.dataset.cat === currentCat;
      const visible = matchYear && matchCat;
      item.classList.toggle('is-hidden', !visible);
      if (visible) visibleCount++;
    });
    if (emptyState) emptyState.hidden = visibleCount > 0;
  }

  yearTabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      yearTabs.forEach((t) => t.classList.remove('is-active'));
      tab.classList.add('is-active');
      if (tab.dataset.year) currentYear = tab.dataset.year;
      applyFilter();
    });
  });

  catBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      catBtns.forEach((b) => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      if (btn.dataset.cat) currentCat = btn.dataset.cat;
      applyFilter();
    });
  });
</script>
