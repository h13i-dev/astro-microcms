---
import type { GetStaticPaths } from 'astro';
import Layout from '../../layouts/Layout.astro';
import ArticleListItem from '../../components/ArticleListItem.astro';
import {
  getCategoriesList,
  getNewsList,
  type CategoryContent,
} from '../../library/microcms';

export const getStaticPaths = (async () => {
  const { contents } = await getCategoriesList({ limit: 100 });
  return contents.map((cat) => ({
    params: { categoryId: cat.id },
    props: { category: cat },
  }));
}) satisfies GetStaticPaths;

interface Props {
  category: CategoryContent;
}

type CategoryId = 'product' | 'event';

const { categoryId } = Astro.params;
const { category } = Astro.props;

const { contents: newsList } = await getNewsList({
  filters: `category[equals]${categoryId}`,
  orders: '-publishedAt',
  limit: 100,
});

const articles = newsList.map((n) => ({
  href: `/news/${n.id}/`,
  date: (n.publishedAt ?? n.createdAt).slice(0, 10),
  title: n.title,
  excerpt: n.description,
}));
---
<Layout title={`${category.name}カテゴリ | Sample Blog`}>
  <main class="main">
    <div class="container">
      <p class="page-lead" style="margin-bottom: 4px;">カテゴリ</p>
      <h1 class="page-title">{category.name}</h1>

      {articles.length > 0 ? (
        <ul class="article-list">
          {articles.map((a) => (
            <ArticleListItem
              href={a.href}
              date={a.date}
              category={categoryId as CategoryId}
              title={a.title}
              excerpt={a.excerpt}
            />
          ))}
        </ul>
      ) : (
        <p class="empty">該当する記事はありません。</p>
      )}
    </div>
  </main>
</Layout>
