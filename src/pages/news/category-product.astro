---
import Layout from '../../layouts/Layout.astro';
import ArticleListItem from '../../components/ArticleListItem.astro';

const articles = [
  {
    href: '/news/article-detail/',
    date: '2026-04-12',
    title: '新製品「Sample Pro X1」を発表しました',
    excerpt: '次世代のフラッグシップモデルとして「Sample Pro X1」を発表しました。従来比2倍の処理速度と新機能を搭載。',
  },
  {
    href: '/news/article-detail/',
    date: '2026-01-30',
    title: '既存製品アップデート（v2.5）リリース',
    excerpt: '使い勝手の改善と新機能を追加するメジャーアップデートをリリースしました。',
  },
  {
    href: '/news/article-detail/',
    date: '2025-09-18',
    title: '新シリーズ「Sample Lite」発売のお知らせ',
    excerpt: 'エントリーモデル向けの新シリーズを2025年10月1日より販売開始します。',
  },
  {
    href: '/news/article-detail/',
    date: '2025-04-01',
    title: '新ブランドラインを発表',
    excerpt: '創業10周年を記念し、新たなブランドラインを発表しました。',
  },
  {
    href: '/news/article-detail/',
    date: '2024-07-15',
    title: '製品ラインナップ刷新のお知らせ',
    excerpt: '既存ラインナップを整理し、新たな3シリーズに再編しました。',
  },
];
---
<Layout title="製品カテゴリ | Sample Blog">
  <main class="main">
    <div class="container">
      <p class="page-lead" style="margin-bottom: 4px;">カテゴリ</p>
      <h1 class="page-title">製品</h1>
      <p class="page-lead">新製品リリース・アップデート情報をお届けします。</p>

      <ul class="article-list">
        {articles.map((a) => (
          <ArticleListItem
            href={a.href}
            date={a.date}
            category="product"
            title={a.title}
            excerpt={a.excerpt}
          />
        ))}
      </ul>

      <nav class="pagination" aria-label="ページ送り">
        <span class="is-current">1</span>
        <a href="#">2</a>
        <a href="#">→</a>
      </nav>
    </div>
  </main>
</Layout>
