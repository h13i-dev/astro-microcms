---
import Layout from '../../layouts/Layout.astro';
import { getInfoList } from '../../library/microcms';

const { contents: infoList } = await getInfoList({
  limit: 100,
  orders: '-publishedAt',
});

const items = infoList.map((info) => {
  const date = (info.publishedAt ?? info.createdAt).slice(0, 10);
  const year = date.slice(0, 4);
  const idSegment = info.id.slice(2);
  const href = info.link ?? `/info/${year}/${idSegment}/`;
  const isExternal = /^https?:\/\//.test(href);
  return {
    href,
    isExternal,
    date,
    year: date.slice(0, 4),
    dateDisplay: date.replaceAll('-', '.'),
    title: info.title,
  };
});

const years = Array.from(new Set(items.map((i) => i.year)))
  .sort()
  .reverse();
const initialYear = years[0] ?? '';
---
<Layout title="お知らせ | Sample Blog">
  <main class="main">
    <div class="container">
      <h1 class="page-title">お知らせ</h1>
      <p class="page-lead">サービス・会社からの各種お知らせを掲載しています。</p>

      <div class="year-tabs" role="tablist">
        {years.map((y) => (
          <button
            class:list={['year-tab', { 'is-active': y === initialYear }]}
            data-year={y}
            role="tab"
          >{y}</button>
        ))}
      </div>

      <ul class="info-list">
        {items.map((item) => (
          <li
            class:list={['info-item', { 'is-hidden': item.year !== initialYear }]}
            data-year={item.year}
          >
            <a
              href={item.href}
              class="info-link"
              target={item.isExternal ? '_blank' : undefined}
              rel={item.isExternal ? 'noopener noreferrer' : undefined}
            >
              <time class="info-date" datetime={item.date}>{item.dateDisplay}</time>
              <span class="info-title">{item.title}</span>
              {item.isExternal && <span class="info-external" aria-label="外部リンク">↗</span>}
            </a>
          </li>
        ))}
      </ul>

      <p class="empty" hidden id="empty-state">該当年のお知らせはありません。</p>
    </div>
  </main>
</Layout>

<script>
  const yearTabs = document.querySelectorAll<HTMLButtonElement>('.year-tab');
  const items = document.querySelectorAll<HTMLLIElement>('.info-item');
  const emptyState = document.getElementById('empty-state') as HTMLParagraphElement | null;

  function applyFilter(year: string) {
    let visibleCount = 0;
    items.forEach((item) => {
      const visible = item.dataset.year === year;
      item.classList.toggle('is-hidden', !visible);
      if (visible) visibleCount++;
    });
    if (emptyState) emptyState.hidden = visibleCount > 0;
  }

  yearTabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      yearTabs.forEach((t) => t.classList.remove('is-active'));
      tab.classList.add('is-active');
      const year = tab.dataset.year;
      if (year) applyFilter(year);
    });
  });
</script>
